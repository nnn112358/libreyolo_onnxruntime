# === モデルファイル (サイズが大きいため Git には含めない) ===
# README の「モデルの入手」を参照して各 *.onnx をリポジトリ直下に配置してください。
*.onnx

# === NPU (AXera/pulsar2) ビルド関連 (公開デモには含めない) ===
# 注: .gitignore は行末コメント非対応。コメントは必ず独立行に書くこと。
# pulsar2 の作業ディレクトリ (~1GB超, 実行毎に再生成, root所有)
work/
# コンパイル済み .axmodel
axmodel/
# キャリブレーション用 npy / tar (make_calib.py で再生成可能)
calib/
*.axmodel
*.tar
*.npy
*_build.log
# NPU 量子化用キャリブレーション生成スクリプト / pulsar2 ビルド設定
make_calib.py
configs/
# pulsar2 の精度解析出力
precision/
PRECISION_*.md

# === uv / Python ===
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.python-version.local

# === OS / エディタ ===
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

